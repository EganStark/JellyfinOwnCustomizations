# Jellyfin Custom Image - Environment Variables
# Copy this file to .env and fill in your values

# ── Jellyfin ──────────────────────────────────────────────────────────────────
# Published port for the Jellyfin web UI
JELLYFIN_PORT=8096
# Published port for HTTPS (optional)
JELLYFIN_HTTPS_PORT=8920

# ── Paths ─────────────────────────────────────────────────────────────────────
# Absolute path on the host where Jellyfin stores its configuration
CONFIG_PATH=./config
# Absolute path on the host used for transcoding temp files
CACHE_PATH=./cache
# Absolute path(s) to your media library
MEDIA_PATH=./media

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC

# ── User / Group IDs (Linux only) ─────────────────────────────────────────────
# Set these to your local UID/GID so file ownership is correct
PUID=1000
PGID=1000
